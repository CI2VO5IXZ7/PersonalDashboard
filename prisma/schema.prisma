generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// User
// ============================================================
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  avatar       String?
  timezone     String   @default("Asia/Shanghai")
  locale       String   @default("zh-CN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mails              MailItem[]
  subscriptions      SubscriptionItem[]
  decisions          DecisionItem[]
  ticktickConnection TickTickConnection?
  setting            UserSetting?
  dockItems          DockItem[]
  bookmarks          Bookmark[]

  @@index([email])
}

// ============================================================
// MailItem
// ============================================================
enum MailFolder {
  inbox
  sent
  draft
  spam
  archived
}

model MailItem {
  id            String     @id @default(cuid())
  userId        String
  folder        MailFolder @default(inbox)
  subject       String
  senderName    String
  senderEmail   String
  receiverEmail String
  summary       String?
  content       String
  isRead        Boolean    @default(false)
  isArchived    Boolean    @default(false)
  isDeleted     Boolean    @default(false)
  isStarred     Boolean    @default(false)
  receivedAt    DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, folder])
  @@index([userId, isRead])
}

// ============================================================
// SubscriptionItem
// ============================================================
model SubscriptionItem {
  id          String   @id @default(cuid())
  userId      String
  sourceName  String
  category    String   @default("tech")
  title       String
  summary     String?
  content     String?
  sourceUrl   String?
  publishedAt DateTime @default(now())
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([userId, isRead])
}

// ============================================================
// DecisionItem
// ============================================================
enum DecisionSourceType {
  mail
  subscription
  ticktick_task
  ticktick_event
  manual
}

enum DecisionPriority {
  urgent
  important
  normal
}

enum DecisionStatus {
  pending
  converted
  dismissed
}

model DecisionItem {
  id              String             @id @default(cuid())
  userId          String
  sourceType      DecisionSourceType @default(manual)
  sourceId        String?
  title           String
  summary         String?
  priority        DecisionPriority   @default(normal)
  status          DecisionStatus     @default(pending)
  suggestedAction String?
  tags            String[]           @default([])
  senderInitials  String?
  receivedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, priority])
}

// ============================================================
// TickTickConnection
// ============================================================
model TickTickConnection {
  id             String    @id @default(cuid())
  userId         String    @unique
  accountName    String?
  accessToken    String
  refreshToken   String?
  tokenExpiresAt DateTime?
  status         String    @default("active")
  lastSyncAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// UserSetting
// ============================================================
model UserSetting {
  id                 String   @id @default(cuid())
  userId             String   @unique
  theme              String   @default("dark")
  locale             String   @default("zh-CN")
  timezone           String   @default("Asia/Shanghai")
  emailNotifications Boolean  @default(true)
  pushNotifications  Boolean  @default(true)
  weeklySummary      Boolean  @default(false)
  securityMode       String   @default("standard")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// DockItem
// ============================================================
model DockItem {
  id         String   @id @default(cuid())
  userId     String
  type       String   @default("module") // module | bookmark
  title      String
  iconType   String   @default("lucide") // lucide | custom | image
  iconValue  String
  targetPath String?
  targetUrl  String?
  openMode   String   @default("internal") // internal | newTab | iframe
  sortOrder  Int      @default(0)
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
}

// ============================================================
// Bookmark
// ============================================================
model Bookmark {
  id            String   @id @default(cuid())
  userId        String
  title         String
  url           String
  iconType      String   @default("lucide")
  iconValue     String   @default("bookmark")
  openMode      String   @default("newTab")
  isPinnedToDock Boolean @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isPinnedToDock])
}
